"""Live strategy engine for signal generation and optional auto-order execution."""
from __future__ import annotations

from dataclasses import dataclass
from typing import Callable

import pandas as pd

from strategy.indicators import ema_signal, macd_signal, rsi_signal


@dataclass
class StrategyDecision:
    strategy: str
    symbol: str
    signal: str
    price: float


class StrategyEngine:
    def __init__(self) -> None:
        self._strategies: dict[str, Callable[[pd.DataFrame], str]] = {
            "EMA_CROSS_9_21": ema_signal,
            "RSI": rsi_signal,
            "MACD": macd_signal,
        }

    def available(self) -> list[str]:
        return list(self._strategies.keys())

    def evaluate(self, strategy_name: str, symbol: str, ohlc: pd.DataFrame) -> StrategyDecision:
        if len(ohlc) < 40:
            return StrategyDecision(strategy_name, symbol, "HOLD", float(ohlc.iloc[-1]["close"]))
        signal = self._strategies[strategy_name](ohlc)
        return StrategyDecision(strategy_name, symbol, signal, float(ohlc.iloc[-1]["close"]))
